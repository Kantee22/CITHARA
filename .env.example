# -------------------------------------------------------------------
# CITHARA — example environment file
# -------------------------------------------------------------------
# Copy this file to `.env` (same folder as manage.py) and fill in the
# values you need. `.env` is git-ignored so your real keys are never
# committed. Django will load these variables automatically when it
# starts (see cithara_project/settings.py).
#
# If you don't create a `.env` file at all, the app still runs —
# GENERATOR_STRATEGY falls back to "mock" and Google login is disabled.
# -------------------------------------------------------------------

# --- Generator strategy (Exercise 4) --------------------------------
# Valid values: "mock" (offline, no credentials) or "suno" (real API).
GENERATOR_STRATEGY=mock

# Suno credentials — only needed when GENERATOR_STRATEGY=suno.
# Get your key from https://sunoapi.org — DO NOT commit the real value.
SUNO_API_KEY=your-suno-api-key-here

# Optional Suno overrides — safe defaults are used if unset.
SUNO_API_BASE_URL=https://api.sunoapi.org/api/v1
SUNO_API_TIMEOUT=30
SUNO_API_MODEL=V4

# --- Google OAuth (Exercise 5 — SRS FR-01) --------------------------
# Create a Web Application OAuth Client in Google Cloud Console:
#   1. https://console.cloud.google.com/apis/credentials
#   2. + Create Credentials → OAuth client ID → Web application
#   3. Authorized JavaScript origins:
#        http://127.0.0.1:8000
#        http://localhost:8000
#   4. Authorized redirect URIs:
#        http://127.0.0.1:8000/accounts/google/login/callback/
#        http://localhost:8000/accounts/google/login/callback/
# Copy the generated Client ID and Client Secret here.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
